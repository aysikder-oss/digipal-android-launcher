{
  "manifest_version": 2,
  "name": "Digipal Bridge",
  "version": "1.0",
  "description": "Native bridge for Digipal signage player",
  "content_scripts": [
    {
      "matches": ["*://*.digipalsignage.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "permissions": ["nativeMessaging"]
}
